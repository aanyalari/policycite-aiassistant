# Answer generation
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_REQUEST_TIMEOUT=180
OLLAMA_NUM_PREDICT=256

# Independent statement-attribution judge
ATTRIBUTION_PROVIDER=ollama
ATTRIBUTION_MODEL=qwen2.5:3b

# Embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text

# Assessment policy corpus
PDF_FOLDER=policy_pdfs
VECTOR_DB=policy_vector_db
CORPUS_PATH=data/policy_corpus.jsonl

# Optional OpenAI configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
